PORT=3083
NODE_ENV=development
MONGODB_URI=mongodb://192.168.2.33:27017/agentx

# Logging
# LOG_LEVEL=info

# Storage Scanner — root directories to scan
# SCANNER_ROOTS=/mnt/nas/media,/mnt/nas/docs

# n8n Webhook (triggered on scan completion)
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/scan-complete
# N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook
# N8N_WEBHOOK_GENERIC=generic

# Live Data — ISS
# ISS_API_URL=http://api.open-notify.org/iss-now.json
# ISS_INTERVAL_MS=10000

# Live Data — Earthquakes
# QUAKES_API_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.csv
# QUAKES_INTERVAL_MS=86400000

# Live Data — Weather/Pressure (requires OpenWeatherMap key)
# WEATHER_API_KEY=

# MQTT (optional — for real-time ISS/pressure publishing)
# MQTT_BROKER_URL=
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_ISS_TOPIC=liveData/iss
# MQTT_PRESSURE_TOPIC=liveData/pressure
